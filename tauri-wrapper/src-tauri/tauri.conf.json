{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-wrapper",
  "version": "0.1.0",
  "identifier": "com.jerry.tauri-wrapper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "tauri-wrapper",
        "width": 800,
        "height": 600,
        "url": "https://demo.rashlink.eu.org",
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
