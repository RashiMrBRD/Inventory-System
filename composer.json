{
    "name": "inventory-demo/inventory-management-system",
    "description": "A modern inventory management system with MongoDB backend and RESTful API",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "dompdf/dompdf": "^3.1",
        "mongodb/mongodb": "^2.1",
        "mpdf/mpdf": "^6.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
