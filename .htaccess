# Root .htaccess - Security Configuration
# This file protects sensitive directories and files

# Prevent directory browsing
Options -Indexes

# Protect sensitive files
<FilesMatch "^(composer\.(json|lock)|\.env|\.gitignore)$">
    Require all denied
</FilesMatch>

# Protect sensitive directories
# Block direct access to source code, config, scripts, and legacy files
RedirectMatch 403 ^/inventory_demo/(src|config|vendor|var|legacy|scripts)/.*$

# Allow documentation and features to be accessible for reference
# But in production, consider restricting these as well

# Redirect all requests to public directory
RewriteEngine On
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/docs/
RewriteCond %{REQUEST_URI} !^/features/
RewriteRule ^(.*)$ public/$1 [L]
