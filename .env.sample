# Application Environment
APP_ENV=development
APP_DEBUG=true
APP_DOMAIN=localhost

# MongoDB Configuration (for Docker)
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=inventory_system
MONGODB_USERNAME=inventory_user
MONGODB_PASSWORD=inventory_pass

# MongoDB Root Credentials (for initialization)
MONGODB_ROOT_USERNAME=admin
MONGODB_ROOT_PASSWORD=adminpassword

# Mongo Express Web Interface
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=pass

# Session Configuration
SESSION_LIFETIME=120
